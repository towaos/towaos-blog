---
interface Props {
  date: Date;
  isUpdated?: boolean;
}

const { date, isUpdated = false } = Astro.props;
---

<time datetime={date.toISOString()}>
  {isUpdated && <span class="date-label">Updated: </span>}
  {date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  })}
</time>
