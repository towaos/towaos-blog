---
import type { BlogPost } from '../types/blog';
import { getDisplayDate, isUpdatedDate } from '../types/blog';
import FormattedDate from './FormattedDate.astro';

interface Props {
  posts: BlogPost[];
  title?: string;
}

const { posts, title = 'Posts' } = Astro.props;
---

<section class="panel listpanel" aria-label="Post list">
  <div class="panel-header">
    <h2>{title}</h2>
    <span id="postCount">{posts.length}</span>
  </div>
  <div class="list post-list-container" id="postList">
    {posts.map((post) => (
      <div class="post-item-wrapper">
        <a href={`/${post.slug}`} class="item post-item">
          <div class="post-title">{post.data.title}</div>
          {post.data.description && (
            <div class="post-excerpt">{post.data.description}</div>
          )}
          <div class="post-date">
            <FormattedDate date={getDisplayDate(post.data)} isUpdated={isUpdatedDate(post.data)} />
          </div>
        </a>
        <div class="post-tags-row" role="list">
          <a 
            href={`/categories/${post.data.category.toLowerCase()}`} 
            class="chip clickable-chip category-chip"
            role="listitem"
          >
            {post.data.category}
          </a>
          {post.data.tags.length > 0 && (
            <>
              {post.data.tags.slice(0, 3).map(tag => (
                <a 
                  href={`/tags/${tag.toLowerCase()}`} 
                  class="chip clickable-chip tag-chip"
                  role="listitem"
                >
                  #{tag}
                </a>
              ))}
              {post.data.tags.length > 3 && (
                <span class="more-tags" role="listitem">+{post.data.tags.length - 3}</span>
              )}
            </>
          )}
        </div>
      </div>
    ))}
  </div>
</section>
