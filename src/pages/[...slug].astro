---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BlogLayout from '../layouts/BlogLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TableOfContents from '../components/TableOfContents.astro';
import BackButton from '../components/BackButton.astro';
import { getDisplayDate, isUpdatedDate } from '../types/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
---

<BlogLayout title={post.data.title} description={post.data.description || post.data.title}>
  <BackButton />

  <div class="layout">
    <div class="sidebar-column">
      <section class="panel current-post-panel" aria-label="Navigation">
        <div class="panel-header">
          <h2>Post</h2>
        </div>
        <div class="current-post-content">
          <div class="current-post-label">
            現在閲覧中の記事
          </div>
          <div class="current-post-title">
            {post.data.title}
          </div>
        </div>
      </section>

      <TableOfContents />
    </div>

    <article class="panel article-panel" aria-label="Post detail">
      <div class="content">
        <h3>{post.data.title}</h3>
        <div class="submeta">
          <span><FormattedDate date={getDisplayDate(post.data)} isUpdated={isUpdatedDate(post.data)} /></span>
          <a href={`/categories/${post.data.category.toLowerCase()}`} class="chip clickable-chip category-chip">
            {post.data.category}
          </a>
          {post.data.tags.length > 0 && (
            <>
              {post.data.tags.map(tag => (
                <a href={`/tags/${tag.toLowerCase()}`} class="chip clickable-chip tag-chip">
                  #{tag}
                </a>
              ))}
            </>
          )}
        </div>
        <div class="body">
          <Content />
        </div>
      </div>
    </article>
  </div>
</BlogLayout>
